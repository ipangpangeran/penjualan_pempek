datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  cogs         Float         @default(0) // Cost of Goods Sold (Harga Asli / Modal)
  isActive     Boolean       @default(true)
  prices       LapakPrice[]
  salesDetails SalesDetail[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model LapakPrice {
  id        Int      @id @default(autoincrement())
  productId Int
  lapakId   Int      // 1: Lapak Ipang, 2: Kang Asep PJP, 3: Kang Asep RDTX & GRHA
  price     Float    @default(0) // Lapak 1 price
  target    Float    @default(0) // Lapak 2/3 target price
  het       Float    @default(0) // Lapak 2/3 HET price
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, lapakId])
}

model SalesHeader {
  id            Int           @id @default(autoincrement())
  invoiceNumber String        @unique
  buyerName     String
  saleDate      DateTime
  lapakId       Int           // 1: Lapak Ipang, 2: Kang Asep PJP, 3: Kang Asep RDTX & GRHA
  totalAmount   Float         // Total Omzet (HET * Qty or price * Qty)
  totalHakIpang Float         // Clean revenue (Target * Qty or price * Qty)
  totalFee      Float         // Reseller fee (7% of HET)
  totalProfit   Float         // Net Profit (totalHakIpang - totalCogs)
  details       SalesDetail[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model SalesDetail {
  id            Int         @id @default(autoincrement())
  salesHeaderId Int
  productId     Int
  qty           Int
  price         Float       // Selling Price (Lapak 1) or HET (Lapak 2 & 3)
  target        Float       // Target price (Lapak 2 & 3)
  het           Float       // HET price (Lapak 2 & 3)
  fee           Float       // Reseller fee
  hakIpang      Float       // Hak Ipang
  omzet         Float       // Omzet
  cogs          Float       // Cost of Goods Sold (Harga Asli) at time of sale
  profit        Float       // Net Profit for this item (hakIpang - cogs * qty)
  subtotal      Float       // price * qty
  salesHeader   SalesHeader @relation(fields: [salesHeaderId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Setting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  username  String
  action    String
  details   String
  createdAt DateTime @default(now())
}
